{
  "name": "pi-arcade-games",
  "version": "1.0.3",
  "description": "Retro terminal arcade for Pi - play games while you wait for builds and tests",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "main": "dist/extensions/arcade.js",
  "files": [
    "dist",
    "skills",
